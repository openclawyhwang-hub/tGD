---
id: repo-index
title: {{ project.name }} — Wiki
sidebar_position: 1
---

import Hero from '@site/src/components/Hero';
import ModuleCard from '@site/src/components/ModuleCard';
import KPIGrid from '@site/src/components/KPIGrid';

<Hero
  title={{ hero_title | tojson }}
  subtitle={{ hero_subtitle | tojson }}
  primary={{ '{' }}{ label: 'Read the Overview', to: '{{ base_path }}/overview' }{{ '}' }}
  secondary={{ '{' }}{ label: 'Explore Architecture', to: '{{ base_path }}/architecture' }{{ '}' }}
/>

<KPIGrid items={{ '{' }}[
  { label: 'Files', value: {{ kpi.files }} },
  { label: 'Modules', value: {{ kpi.modules }} },
  { label: 'Flows', value: {{ kpi.flows }} },
  { label: 'Dependencies', value: {{ kpi.edges }} },
]{{ '}' }} />

## 🧩 Modules

<div className="tgd-module-grid">
{% for m in modules %}
  <ModuleCard
    title={{ m.title | tojson }}
    slug={{ ("repos/" ~ repo_slug ~ "/modules/" ~ m.slug) | tojson }}
    summary={{ m.summary | tojson }}
    fileCount={ {{- m.file_count -}} }
    symbolCount={ {{- m.symbol_count -}} }
    icon={{ m.icon | tojson }}
    accent={{ m.accent | tojson }}
  />
{% endfor %}
</div>

## 🔄 Flows

{% if flows %}
{% for f in flows %}
- [{{ f.title }}]({{ base_path }}/flows/{{ f.slug }})
{% endfor %}
{% else %}
_No named flows were captured. Add a tour to the Understand-Anything analysis to seed flows._
{% endif %}

## 🗺️ Diagrams

- [Architecture diagram]({{ base_path }}/diagrams#architecture)
- [Dependency diagram]({{ base_path }}/diagrams#dependencies)

## 📚 References

- Repo path: `{{ repo_path }}`
- Knowledge graph: `$TGD_DIR/.scans/{{ repo_slug }}/.understand-anything/knowledge-graph.json`
{% if dashboard_url %}
- [Interactive Dashboard]({{ dashboard_url }})
{% endif %}

{% if all_repos and all_repos | length > 1 %}
## Switch Repository

{% for r in all_repos %}
{% if r.slug != repo_slug %}
- [{{ r.icon }} {{ r.name }}]({{ r.base_path }}){{ " ⭐" if r.is_primary else "" }}
{% endif %}
{% endfor %}
{% endif %}

