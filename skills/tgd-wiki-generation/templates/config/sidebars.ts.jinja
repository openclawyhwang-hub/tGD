import type {SidebarsConfig} from '@docusaurus/plugin-content-docs';

const sidebars: SidebarsConfig = {
  wiki: [
    {type: 'doc', id: 'home', label: '🏠 Home'},
    {type: 'doc', id: 'sources', label: '📚 All Sources'},
    {% for r in repos %}
    {
      type: 'category',
      label: {{ (r.name ~ (" ⭐" if r.slug == primary_slug else "")) | tojson }},
      collapsed: {{ 'false' if r.slug == primary_slug else 'true' }},
      link: {type: 'doc', id: 'repos/{{ r.slug }}/repo-index'},
      items: [
        {type: 'doc', id: 'repos/{{ r.slug }}/overview', label: 'Overview'},
        {type: 'doc', id: 'repos/{{ r.slug }}/architecture', label: 'Architecture'},
        {type: 'doc', id: 'repos/{{ r.slug }}/onboarding', label: 'Onboarding'},
        {% if r.modules %}
        {
          type: 'category',
          label: 'Modules',
          collapsed: true,
          items: [
            {% for m in r.modules %}
            {type: 'doc', id: 'repos/{{ r.slug }}/modules/{{ m.slug }}', label: {{ m.title | tojson }}},
            {% endfor %}
          ],
        },
        {% endif %}
        {% if r.flows %}
        {
          type: 'category',
          label: 'Flows',
          collapsed: true,
          items: [
            {% for f in r.flows %}
            {type: 'doc', id: 'repos/{{ r.slug }}/flows/{{ f.slug }}', label: {{ f.title | tojson }}},
            {% endfor %}
          ],
        },
        {% endif %}
        {type: 'doc', id: 'repos/{{ r.slug }}/diagrams/diagrams-index', label: 'Diagrams'},
      ],
    },
    {% endfor %}
  ],
};

export default sidebars;
